# ============================================================
# APP NTRL — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git
# ============================================================

# Base de datos PostgreSQL
POSTGRES_USER=ntrl_user
POSTGRES_PASSWORD=cambia_esta_clave_segura
POSTGRES_DB=ntrl_db

# Redis
REDIS_PASSWORD=cambia_esta_clave_redis

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=genera_un_secreto_largo_aqui_64_bytes_minimo
JWT_REFRESH_SECRET=genera_otro_secreto_diferente_aqui_64_bytes_minimo

# Cloudinary — almacenamiento de imágenes (avatares, archivos)
# Obtén esta URL en: cloudinary.com → Settings → API Keys → "API Environment Variable"
# REQUERIDA en producción (Render). Sin ella, los archivos se guardan localmente y se pierden al reiniciar.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# CORS — IPs o dominios permitidos (separados por coma)
# En producción: la IP del servidor en la red local
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
